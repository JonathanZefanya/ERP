@using Microsoft.AspNetCore.Builder
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Options

@inject IViewLocalizer Localizer
@inject IOptions<RequestLocalizationOptions> LocOptions

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCultureName = requestCulture?.RequestCulture.UICulture.Name ?? "en";
    var currentCultureCode = requestCulture?.RequestCulture.UICulture.TwoLetterISOLanguageName.ToUpperInvariant() ?? "EN";
    var selectorMode = (ViewData["CultureSelectorMode"] as string ?? string.Empty).ToLowerInvariant();
    var cultureItems = LocOptions.Value.SupportedUICultures
    .Select(c => new SelectListItem { Value = c.Name, Text = c.TwoLetterISOLanguageName.ToUpperInvariant() })
    .ToList();
    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "~/" :
    $"~{Context.Request.Path.Value}{Context.Request.QueryString}";
}

@if (selectorMode == "login-menu")
{
    <div class="dropdown language-menu-shell" title="@Localizer["Request culture provider:"] @requestCulture?.Provider?.GetType().Name">
        <button type="button" class="btn btn-language language-menu-trigger dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="@Localizer["Select language"]">
            <i class="fas fa-globe" aria-hidden="true"></i>
            <span>@Localizer["Language"]</span>
            <span class="language-current-code">@currentCultureCode</span>
            <i class="fas fa-chevron-down language-menu-caret" aria-hidden="true"></i>
        </button>
        <div class="dropdown-menu dropdown-menu-right language-menu-dropdown" aria-label="@Localizer["Language options"]">
            @foreach (var item in cultureItems)
            {
                var isCurrent = string.Equals(item.Value, currentCultureName, StringComparison.OrdinalIgnoreCase);
                <form asp-controller="Culture" asp-action="SetCulture" asp-route-returnUrl="@returnUrl" method="post" class="language-menu-form" role="none">
                    <input type="hidden" name="culture" value="@item.Value" />
                    <button type="submit" class="dropdown-item language-menu-item @(isCurrent ? "active" : string.Empty)" role="menuitem" aria-current="@(isCurrent ? "true" : "false")">
                        <span class="language-menu-code">@item.Text</span>
                        @if (isCurrent)
                        {
                            <i class="fas fa-check" aria-hidden="true"></i>
                        }
                    </button>
                </form>
            }
        </div>
    </div>
}
else
{
    <div class="dropdown language-header-shell" title="@Localizer["Request culture provider:"] @requestCulture?.Provider?.GetType().Name">
        <button type="button" class="btn language-header-trigger dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="@Localizer["Select language"]">
            <i class="fas fa-globe" aria-hidden="true"></i>
            <span class="language-header-code">@currentCultureCode</span>
        </button>
        <div class="dropdown-menu dropdown-menu-right language-header-dropdown" aria-label="@Localizer["Language options"]">
            @foreach (var item in cultureItems)
            {
                var isCurrent = string.Equals(item.Value, currentCultureName, StringComparison.OrdinalIgnoreCase);
                <form asp-controller="Culture" asp-action="SetCulture" asp-route-returnUrl="@returnUrl" method="post" class="language-header-form" role="none">
                    <input type="hidden" name="culture" value="@item.Value" />
                    <button type="submit" class="dropdown-item language-header-item @(isCurrent ? "active" : string.Empty)" role="menuitem" aria-current="@(isCurrent ? "true" : "false")">
                        <span class="language-header-item-code">@item.Text</span>
                        @if (isCurrent)
                        {
                            <i class="fas fa-check" aria-hidden="true"></i>
                        }
                    </button>
                </form>
            }
        </div>
    </div>
}