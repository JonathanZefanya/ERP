@model BusinessERP.Models.DashboardViewModel.DashboardSummaryViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer localizer

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-container">
    <!-- Header Section -->
    <div class="dashboard-header">
        <h1 class="dashboard-title">
            <i class="bi bi-speedometer2"></i>
            @localizer["Dashboard"]
        </h1>
        <div class="dashboard-date">
            <i class="bi bi-calendar-event"></i>
            <span id="currentDateTime"></span>
        </div>
    </div>

    <!-- Summary Cards -->
    @await Html.PartialAsync("_PaymentAndItemSummary", Model)

    <!-- Charts Section - Reorganized -->

    <div class="row charts-section">
        <!-- Pie Chart - Full Width -->
        <div class="col-md-12">
            @await Html.PartialAsync("_PieChartHighestEarning", Model)
        </div>
    </div>
    <div class="row charts-section">
        <!-- Bar Chart - Full Width -->
        <div class="col-md-12">
            @await Html.PartialAsync("_BarChartMonthlySales", Model)
        </div>
    </div>

    <!-- Recent Invoice Section -->
    <div class="row">
        <div class="col-md-12">
            @await Html.PartialAsync("_RecentInvoice", Model)
        </div>
    </div>
</div>

<!-- Load Scripts -->
<script src="https://code.highcharts.com/highcharts.js"></script>
<script src="~/js/dataHighcharts.js"></script>

<script>
    // Update current date and time
    function updateDateTime() {
        const now = new Date();
        const options = {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        };
        const dateElement = document.getElementById('currentDateTime');
        if (dateElement) {
            dateElement.textContent = now.toLocaleDateString('en-US', options);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
            updateDateTime();
            setInterval(updateDateTime, 60000);
        });
    } else {
        updateDateTime();
        setInterval(updateDateTime, 60000);
    }
</script>